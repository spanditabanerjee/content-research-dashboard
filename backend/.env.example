# Server
NODE_ENV=development
PORT=5001

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT_MS=60000
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Reddit API — https://www.reddit.com/prefs/apps (create "script" or "web app")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ContentResearchDashboard/1.0 (by /u/yourusername)
REDDIT_OAUTH_URL=https://www.reddit.com/api/v1/access_token
REDDIT_API_BASE_URL=https://oauth.reddit.com
REDDIT_SEARCH_LIMIT=5
REDDIT_REQUEST_TIMEOUT_MS=10000
